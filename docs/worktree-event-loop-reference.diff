+fn drain_buffered_llm_results(
+    app: &mut App,
+    buffered_llm_results: &mut Vec<LlmClassification>,
+    max_results: usize,
+) {
+    if buffered_llm_results.is_empty()
+        || app.scan_status == ScanStatus::Scanning
+        || app.entries.is_empty()
+    {
+        return;
+    }
+
+    let drain_count = buffered_llm_results.len().min(max_results);
+    let results = buffered_llm_results
+        .drain(..drain_count)
+        .collect::<Vec<_>>();
+    apply_llm_results(app, results);
+}
+
+fn drain_llm_result_batches(
+    app: &mut App,
+    result_rx: Option<&LlmResultReceiver>,
+    buffered_llm_results: &mut Vec<LlmClassification>,
+    max_batches: usize,
+) {
+    let Some(result_rx) = result_rx else {
+        return;
+    };
+
+    let mut processed = 0;
+    while processed < max_batches {
+        match result_rx.try_recv() {
+            Ok(results) => {
+                if app.scan_status == ScanStatus::Scanning && app.entries.is_empty() {
+                    buffered_llm_results.extend(results);
+                } else {
+                    apply_llm_results(app, results);
                 }
-                Event::Mouse(mouse) => {
-                    let size = terminal.size()?;
-                    let layout =
-                        ui::main_layout(ratatui::layout::Rect::new(0, 0, size.width, size.height));
-                    input::handle_mouse(app, mouse, layout);
+                processed += 1;
+            }
+            Err(_) => break,
+        }
+    }
+}
+
+fn drain_ready_events<P, R, H>(
+    max_events: usize,
+    mut poll: P,
+    mut read: R,
+    mut handle: H,
+) -> io::Result<bool>
+where
+    P: FnMut() -> io::Result<bool>,
+    R: FnMut() -> io::Result<Event>,
+    H: FnMut(Event) -> io::Result<()>,
+{
+    let mut handled_any = false;
+    let mut remaining = max_events;
+    while remaining > 0 && poll()? {
+        handle(read()?)?;
+        handled_any = true;
+        remaining -= 1;
+    }
+    Ok(handled_any)
+}

+#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
+pub enum AgeBucket {
+    Older,
+    Last30Days,
+    Last7Days,
+    Today,
+    Unknown,
+}
+
+impl AgeBucket {
+    fn for_modified(modified: Option<SystemTime>) -> Self {
+        let Some(modified) = modified else {
+            return Self::Unknown;
+        };
+
+        let Ok(age) = SystemTime::now().duration_since(modified) else {
+            return Self::Today;
+        };
+
+        if age.as_secs() <= 24 * 60 * 60 {
+            Self::Today
+        } else if age.as_secs() <= 7 * 24 * 60 * 60 {
+            Self::Last7Days
+        } else if age.as_secs() <= 30 * 24 * 60 * 60 {
+            Self::Last30Days
+        } else {
+            Self::Older
+        }
+    }
+
+    fn label(self) -> &'static str {
+        match self {
+            Self::Older => "Older",
+            Self::Last30Days => "Last 30 Days",
+            Self::Last7Days => "Last 7 Days",
+            Self::Today => "Today",
+            Self::Unknown => "Unknown Age",
+        }
+    }
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
+pub enum SectionKey {
+    Type(Category),
+    Safety(SafetyLevel),
+    Age(AgeBucket),
+}
+
+impl Hash for SectionKey {
+    fn hash<H: Hasher>(&self, state: &mut H) {
+        match self {
+            Self::Type(category) => {
+                0_u8.hash(state);
+                (*category as u8).hash(state);
+            }
+            Self::Safety(safety) => {
+                1_u8.hash(state);
+                (*safety as u8).hash(state);
+            }
+            Self::Age(bucket) => {
+                2_u8.hash(state);
+                bucket.hash(state);
+            }
+        }
+    }
+}
+
+impl SectionKey {
+    fn label(self) -> String {
+        match self {
+            Self::Type(category) => category.to_string(),
+            Self::Safety(safety) => safety.to_string(),
+            Self::Age(bucket) => bucket.label().to_string(),
+        }
+    }
+}

+    fn build_grouped_rows<F, S>(
+        &self,
+        entries: Vec<FlatEntry>,
+        sort_entries: S,
+        section_key: F,
+    ) -> Vec<FlatRow>
+    where
+        F: Fn(&FlatEntry) -> SectionKey,
+        S: Fn(&FlatEntry, &FlatEntry) -> Ordering,
+    {
+        let mut groups = BTreeMap::<SectionKey, Vec<FlatEntry>>::new();
+        for entry in entries {
+            groups.entry(section_key(&entry)).or_default().push(entry);
+        }
+
+        let mut rows = Vec::new();
+        for (key, mut group_entries) in groups {
+            group_entries.sort_by(|a, b| sort_entries(a, b));
+            let expanded = !self.collapsed_sections.contains(&key);
+            rows.push(FlatRow::Section(SectionRow {
+                key,
+                label: key.label(),
+                item_count: group_entries.len(),
+                expanded,
+            }));
+
+            if expanded {
+                rows.extend(group_entries.into_iter().map(FlatRow::Entry));
+            }
+        }
+
+        rows
